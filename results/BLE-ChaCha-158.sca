attr seedset 8
itervar auth false
itervar nonce false
itervar seqcheck false
itervar temp 28
itervar timecheck false
config cmdenv-express-mode true
config network BLEScenario
config *.algorithm "\"ChaCha20-Poly1305\""
config *.sensor.algorithm "\"ChaCha20-Poly1305\""
config *.ac.algorithm "\"ChaCha20-Poly1305\""
config sim-time-limit 150s
config repeat 10
config seed-set 8
config ned-path ../src;.
config output-vector-file ../results/BLE-ChaCha-158.vec
